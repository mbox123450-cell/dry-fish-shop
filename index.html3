<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Helina Dry Fish Market</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      background:#f5f5f5;
      color:#333;
    }

    header{
      background:#0d3b2e;
      color:white;
      padding:20px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      flex-wrap:wrap;
    }

    header h1{
      font-size:28px;
    }

    nav a{
      color:white;
      text-decoration:none;
      margin:0 10px;
      font-weight:bold;
    }

    .hero{
      background:url('https://images.unsplash.com/photo-1579631542720-3a87824fff86?q=80&w=1200&auto=format&fit=crop') center/cover;
      height:400px;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      color:white;
      padding:20px;
    }

    .hero-content{
      background:rgba(0,0,0,0.6);
      padding:30px;
      border-radius:10px;
      max-width:600px;
    }

    .hero h2{
      font-size:40px;
      margin-bottom:15px;
    }

    .hero p{
      margin-bottom:20px;
      line-height:1.6;
    }

    .btn{
      background:#ff9800;
      color:white;
      padding:12px 25px;
      border:none;
      border-radius:5px;
      text-decoration:none;
      font-weight:bold;
      display:inline-block;
    }

    section{
      padding:60px 20px;
    }

    .section-title{
      text-align:center;
      margin-bottom:40px;
      font-size:32px;
      color:#0d3b2e;
    }

    .products{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:25px;
    }

    .card{
      background:white;
      border-radius:10px;
      overflow:hidden;
      box-shadow:0 4px 10px rgba(0,0,0,0.1);
      transition:0.3s;
    }

    .card:hover{
      transform:translateY(-5px);
    }

    .card img{
      width:100%;
      height:220px;
      object-fit:cover;
    }

    .card-content{
      padding:20px;
    }

    .card h3{
      margin-bottom:10px;
    }

    .price{
      color:#ff9800;
      font-size:22px;
      font-weight:bold;
      margin-bottom:15px;
    }

    .about{
      background:white;
      border-radius:10px;
      max-width:900px;
      margin:auto;
      padding:30px;
      line-height:1.8;
      box-shadow:0 4px 10px rgba(0,0,0,0.1);
    }

    .contact{
      text-align:center;
    }

    .contact p{
      margin:10px 0;
      font-size:18px;
    }

    footer{
      background:#0d3b2e;
      color:white;
      text-align:center;
      padding:20px;
      margin-top:40px;
    }

    @media(max-width:768px){
      .hero h2{
        font-size:28px;
      }

      header{
        flex-direction:column;
        gap:10px;
      }
    }
  </style>
</head>

<body>

  <header>
    <h1>🐟 Helina Dry Fish Market</h1>

    <nav>
      <a href="#products">Products</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <section class="hero">
    <div class="hero-content">
      <h2>Fresh & Premium Dry Fish</h2>

      <p>
        We provide quality smoked and dried seafood for homes,
        restaurants, and markets.
      </p>

      <a href="#products" class="btn">Shop Now</a>
    </div>
  </section>

  <section id="products">
    <h2 class="section-title">Our Products</h2>

    <div class="products">

      <div class="card">
        <img src="https://images.unsplash.com/photo-1615141982883-c7ad0e69fd62?q=80&w=800&auto=format&fit=crop">

        <div class="card-content">
          <h3>Smoked Tilapia</h3>
          <p class="price">GH₵ 120</p>

          <a href="https://wa.me/233000000000" class="btn">
            Order Now
          </a>
        </div>
      </div>

      <div class="card">
        <img src="https://images.unsplash.com/photo-1510130387422-82bed34b37e9?q=80&w=800&auto=format&fit=crop">

        <div class="card-content">
          <h3>Dried Salmon</h3>
          <p class="price">GH₵ 180</p>

          <a href="https://wa.me/233000000000" class="btn">
            Order Now
          </a>
        </div>
      </div>

      <div class="card">
        <img src="https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?q=80&w=800&auto=format&fit=crop">

        <div class="card-content">
          <h3>Catfish Pack</h3>
          <p class="price">GH₵ 150</p>

          <a href="https://wa.me/233000000000" class="btn">
            Order Now
          </a>
        </div>
      </div>

    </div>
  </section>

  <section id="about">
    <h2 class="section-title">About Us</h2>

    <div class="about">
      <p>
        Helina Dry Fish Market is a trusted seafood business
        delivering fresh and quality dry fish products to customers
        across Ghana and beyond.
      </p>

      <p>
        We focus on hygiene, freshness, and customer satisfaction.
        Whether you are buying for your home, restaurant, or business,
        we provide premium products at affordable prices.
      </p>
    </div>
  </section>

  <section id="contact">
    <h2 class="section-title">Contact Us</h2>

    <div class="contact">
      <p>📍 Accra, Ghana</p>
      <p>📞 +233 542946812</p>
      <p>📧 helinadryfish@gmail.com</p>

      <br>

      <a href="https://wa.me/233000000000" class="btn">
        Chat on WhatsApp
      </a>
    </div>
  </section>

  <footer>
    <p>© 2026 Helina Dry Fish Market. All Rights Reserved.</p>
  </footer>

</body>
</html>
